# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Required
FIGMA_PAT=figd_your_token_here
FIGWATCH_WEBHOOK_PASSCODE=choose-a-secret-passphrase

# AI provider — choose one (Gemini has a free tier)
GOOGLE_API_KEY=your_google_ai_key_here      # for Gemini (recommended — free tier available)
# ANTHROPIC_API_KEY=sk-ant-your_key_here    # for Claude (sonnet / opus / haiku)

# Optional (defaults shown)
FIGWATCH_MODEL=gemini-flash    # or: gemini-flash-lite, sonnet, opus, haiku
FIGWATCH_LOCALE=uk             # uk, de, fr, nl, benelux
FIGWATCH_PORT=8080
FIGWATCH_WORKERS=4             # Concurrent worker threads
FIGWATCH_MAX_ATTEMPTS=3        # Retry attempts per audit before giving up

# Rate limiting — set to 0 to disable
FIGWATCH_GEMINI_RPM=15         # Gemini free tier default
FIGWATCH_ANTHROPIC_RPM=5       # Anthropic Tier 1 conservative default
FIGWATCH_QUEUE_UPDATE_RPM=5    # Live queue-position ack updates per minute (0 disables)

# Logging
FIGWATCH_LOG_LEVEL=INFO        # DEBUG, INFO, WARNING, ERROR
FIGWATCH_LOG_FORMAT=text       # text (Dozzle-friendly) or json (for log aggregators)

# Optional — restrict to specific files (comma-separated URLs or file keys)
# If unset, FigWatch handles comments from all files in your Figma team.
# FIGWATCH_FILES=https://www.figma.com/design/yourFileKey/your-file-name
